# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for source files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.md   text eol=lf 
*.json text eol=lf
*.py   text eol=lf
*.txt  text eol=lf
*.env  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.ico  binary